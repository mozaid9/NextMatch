# Copy this file to `.env.firebase`, fill in the real values from Firebase,
# and run Flutter with:
# flutter run -d chrome --dart-define-from-file=.env.firebase
#
# These values are client config, not server secrets, but they should still
# stay out of Git and be restricted in Google Cloud Console.

NEXTMATCH_FIREBASE_PROJECT_ID=nextmatch-eb038
NEXTMATCH_FIREBASE_AUTH_DOMAIN=nextmatch-eb038.firebaseapp.com
NEXTMATCH_FIREBASE_STORAGE_BUCKET=nextmatch-eb038.firebasestorage.app
NEXTMATCH_FIREBASE_MESSAGING_SENDER_ID=REPLACE_WITH_SENDER_ID

NEXTMATCH_FIREBASE_WEB_API_KEY=REPLACE_WITH_WEB_API_KEY
NEXTMATCH_FIREBASE_WEB_APP_ID=REPLACE_WITH_WEB_APP_ID
NEXTMATCH_FIREBASE_WEB_MEASUREMENT_ID=REPLACE_WITH_WEB_MEASUREMENT_ID

NEXTMATCH_FIREBASE_ANDROID_API_KEY=REPLACE_WITH_ANDROID_API_KEY
NEXTMATCH_FIREBASE_ANDROID_APP_ID=REPLACE_WITH_ANDROID_APP_ID

NEXTMATCH_FIREBASE_IOS_API_KEY=REPLACE_WITH_IOS_API_KEY
NEXTMATCH_FIREBASE_IOS_APP_ID=REPLACE_WITH_IOS_APP_ID
NEXTMATCH_IOS_BUNDLE_ID=com.nextmatch.nextMatch

NEXTMATCH_FIREBASE_MACOS_API_KEY=REPLACE_WITH_MACOS_API_KEY
NEXTMATCH_FIREBASE_MACOS_APP_ID=REPLACE_WITH_MACOS_APP_ID
NEXTMATCH_MACOS_BUNDLE_ID=com.nextmatch.nextMatch

NEXTMATCH_FIREBASE_WINDOWS_API_KEY=REPLACE_WITH_WINDOWS_API_KEY
NEXTMATCH_FIREBASE_WINDOWS_APP_ID=REPLACE_WITH_WINDOWS_APP_ID
NEXTMATCH_FIREBASE_WINDOWS_MEASUREMENT_ID=REPLACE_WITH_WINDOWS_MEASUREMENT_ID

NEXTMATCH_FIREBASE_LINUX_API_KEY=REPLACE_WITH_LINUX_API_KEY
NEXTMATCH_FIREBASE_LINUX_APP_ID=REPLACE_WITH_LINUX_APP_ID
