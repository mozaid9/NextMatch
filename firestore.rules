rules_version = '2';

// NextMatch Firestore security rules.
//
// Model: the whole database requires authentication. Users own their profile
// and private subcollections. Organisers control their matches and may write
// the participant-facing bookkeeping their dashboard performs (approvals,
// attendance, joined-match summaries). Cross-user writes that the client
// currently performs (reliability counters, ability ratings) are constrained
// to exact field allowlists — they remain the weakest link and should move
// to Cloud Functions before real payments launch (see SECURITY.md).
//
// Paid joins are confirmed exclusively by the Stripe webhook Cloud
// Function (admin SDK, bypasses rules). Clients can only ever create
// pending entries on paid matches.

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function matchDoc(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId));
    }

    function participantDoc(matchId, userId) {
      return get(/databases/$(database)/documents/matches/$(matchId)/participants/$(userId));
    }

    function isMatchOrganiser(matchId) {
      return signedIn() && matchDoc(matchId).data.organiserId == request.auth.uid;
    }

    function isMatchParticipant(matchId) {
      return signedIn()
        && exists(/databases/$(database)/documents/matches/$(matchId)/participants/$(request.auth.uid));
    }

    // A freed spot can be held for a waitlisted player (reservedForUid /
    // reservedUntil, written by the backend). While that hold is live, only
    // the reserved player may take the spot. An absent or expired hold is
    // claimable by anyone.
    function spotClaimableBy(matchData) {
      return matchData.get('reservedForUid', null) == null
        || matchData.get('reservedUntil', request.time) < request.time
        || matchData.reservedForUid == request.auth.uid;
    }

    function isInvitedToMatch(matchId) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/matchInvites/$(matchId));
    }

    // Match chat is for people actually involved in the game: the
    // organiser, or a participant who holds (or is securing) a spot.
    function canWriteMatchComment(matchId) {
      return isMatchOrganiser(matchId)
        || (isMatchParticipant(matchId)
          && participantDoc(matchId, request.auth.uid).data.attendanceStatus in [
            'Joined',
            'PendingPayment',
            'Attended'
          ]);
    }

    // Player joins bump the counter by one; status may flip Open <-> Full.
    // Only free-to-join matches: on paid Split matches the Stripe webhook
    // (admin SDK) is the only thing that bumps the counter.
    function validJoinCounterUpdate() {
      return signedIn()
        && (resource.data.paymentMode == 'OrganiserPays'
          || resource.data.pricePerPlayer == 0)
        && spotClaimableBy(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'joinedPlayerCount',
          'status',
          'updatedAt'
        ])
        && resource.data.joinedPlayerCount < resource.data.totalPlayersNeeded
        && request.resource.data.joinedPlayerCount == resource.data.joinedPlayerCount + 1
        && request.resource.data.status in ['Open', 'Full'];
    }

    function validWithdrawCounterUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'joinedPlayerCount',
          'status',
          'updatedAt'
        ])
        && request.resource.data.joinedPlayerCount == resource.data.joinedPlayerCount - 1
        && request.resource.data.joinedPlayerCount >= 0
        && request.resource.data.status in ['Open', 'Full'];
    }

    // Players may create their own pending entries freely, but a 'Joined'
    // entry straight away only on matches with nothing to pay — paid spots
    // are confirmed by the Stripe webhook, never the client.
    function validSelfParticipantCreate(matchId, participantId) {
      return owns(participantId)
        && request.resource.data.userId == request.auth.uid
        && spotClaimableBy(matchDoc(matchId).data)
        && (request.resource.data.attendanceStatus in [
            'PendingPayment',
            'PendingApproval'
          ]
          || (request.resource.data.attendanceStatus == 'Joined'
            && (matchDoc(matchId).data.paymentMode == 'OrganiserPays'
              || matchDoc(matchId).data.pricePerPlayer == 0)));
    }

    function validSelfWithdraw(participantId) {
      return owns(participantId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendanceStatus',
          'cancelledAt',
          'withdrawalReason',
          'updatedAt'
        ])
        && resource.data.attendanceStatus in [
          'Joined',
          'PendingPayment',
          'PendingApproval'
        ]
        && request.resource.data.attendanceStatus in [
          'Cancelled',
          'LateCancelled'
        ];
    }

    function completedMatch(matchId) {
      return matchDoc(matchId).data.status == 'Completed';
    }

    function attended(matchId, userId) {
      return participantDoc(matchId, userId).data.attendanceStatus == 'Attended';
    }

    // Reputation fields are written ONLY by Cloud Functions (admin SDK,
    // which bypasses these rules). No client may touch them — not even on
    // its own profile doc — so a player can never inflate their own score.
    function touchesReputation() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'reliabilityScore',
        'abilityRating',
        'rating',
        'abilityRatingCount',
        'completedMatches',
        'cancelledMatches',
        'lateCancellations',
        'noShows',
        'attendedMatches',
        'matchesPlayed',
        'lastReliabilityUpdateAt',
        'lastAbilityRatingAt'
      ]);
    }

    function validRatedFlagUpdate(matchId) {
      return signedIn()
        && completedMatch(matchId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isRated'
        ])
        && request.resource.data.isRated == true;
    }

    match /users/{userId} {
      // Profiles power player search and match tiles; auth required,
      // unauthenticated scraping blocked.
      allow read: if signedIn();
      // New accounts are created with their starting scores; after that the
      // owner may edit their profile but never the reputation fields.
      allow create: if owns(userId);
      allow update: if owns(userId) && !touchesReputation();
      allow delete: if false;

      // Social graph: I write my own "following" list, and I write my own
      // entry into the target's "followers" list. Nobody else can touch
      // either side.
      match /following/{targetUid} {
        allow read: if signedIn();
        allow create, delete: if owns(userId);
        allow update: if false;
      }

      match /followers/{followerUid} {
        allow read: if signedIn();
        allow create, delete: if owns(followerUid);
        allow update: if false;
      }

      // Legacy pre-follow friendships. Dead data — readable by owner so old
      // accounts don't break, never writable.
      match /friends/{friendUid} {
        allow read: if owns(userId);
        allow write: if false;
      }

      match /favouriteVenues/{venueId} {
        allow read, write: if owns(userId);
      }

      // Push notification device tokens. Owner-only; Cloud Functions read
      // them with admin privileges when fanning out notifications.
      match /fcmTokens/{token} {
        allow read, write: if owns(userId);
      }

      // In-app notification feed, written by Cloud Functions (admin SDK
      // bypasses rules). The owner can read, mark as read, and clear.
      match /notifications/{notificationId} {
        allow read, delete: if owns(userId);
        allow update: if owns(userId)
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['read']);
        allow create: if false;
      }

      // Invites are written into the invitee's inbox by the inviter and
      // dismissed by the invitee.
      match /matchInvites/{matchId} {
        allow read: if owns(userId);
        allow create: if signedIn()
          && request.resource.data.inviterUid == request.auth.uid;
        allow delete: if owns(userId);
        allow update: if false;
      }

      // Denormalised summaries the organiser maintains alongside the
      // participant doc (approval, cancellation, completion).
      match /joinedMatches/{matchId} {
        allow read: if owns(userId);
        allow create, update: if owns(userId) || isMatchOrganiser(matchId);
        allow delete: if false;
      }

      // Reliability events and ability-rating evidence are written only by
      // Cloud Functions (admin SDK) — the audit trail behind the scores.
      match /reliabilityEvents/{eventId} {
        allow read: if owns(userId);
        allow write: if false;
      }

      match /abilityRatings/{ratingId} {
        allow read: if owns(userId);
        allow write: if false;
      }
    }

    // Unique @handle reservation index. One doc per handle (id = the
    // canonical lowercase handle), value = { uid }. Anyone signed in can read
    // (availability checks and profile lookups). You may only claim a free
    // handle for yourself and only release one you own. Handles are immutable
    // — a change is a delete of the old plus a create of the new — so updates
    // are forbidden, which is precisely what stops one player overwriting
    // another player's handle.
    match /usernames/{handle} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'createdAt']);
      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    match /matches/{matchId} {
      // Single-doc reads: public matches, plus private ones you organise,
      // joined, or were invited to.
      allow get: if signedIn()
        && (resource.data.visibility == 'Public'
          || resource.data.organiserId == request.auth.uid
          || isMatchParticipant(matchId)
          || isInvitedToMatch(matchId));

      // Queries must constrain to public matches or your own
      // (openMatchesStream filters visibility == 'Public';
      // organisedMatchesStream filters organiserId == uid).
      allow list: if signedIn()
        && (resource.data.visibility == 'Public'
          || resource.data.organiserId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.organiserId == request.auth.uid
        && request.resource.data.joinedPlayerCount == 0;

      allow update: if isMatchOrganiser(matchId)
        || validJoinCounterUpdate()
        || validWithdrawCounterUpdate()
        || validRatedFlagUpdate(matchId);

      allow delete: if isMatchOrganiser(matchId);

      match /participants/{participantId} {
        allow read: if signedIn();
        // Players create their own entry; organisers also write entries
        // (reject, attendance bookkeeping).
        allow create: if validSelfParticipantCreate(matchId, participantId)
          || isMatchOrganiser(matchId);
        allow update: if isMatchOrganiser(matchId)
          || validSelfWithdraw(participantId);
        allow delete: if false;
      }

      // Waitlist for a full match. A player adds and removes their own entry
      // as 'Waiting'; the status transitions (Offered / Claimed / Expired)
      // and the spot reservation are written only by Cloud Functions.
      match /waitlist/{waitlistId} {
        allow read: if signedIn();
        allow create: if owns(waitlistId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.status == 'Waiting';
        allow delete: if owns(waitlistId);
        allow update: if false;
      }

      // Match chat — only people involved in the game can post.
      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if canWriteMatchComment(matchId)
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 500;
        allow update: if false;
        allow delete: if signedIn()
          && (resource.data.authorUid == request.auth.uid
            || isMatchOrganiser(matchId));
      }

      match /ratings/{ratingId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && completedMatch(matchId)
          && request.resource.data.ratedByUserId == request.auth.uid
          && request.resource.data.ratedUserId != request.auth.uid
          && attended(matchId, request.auth.uid)
          && attended(matchId, request.resource.data.ratedUserId)
          && request.resource.data.abilityRating >= 1
          && request.resource.data.abilityRating <= 5;
        allow update, delete: if false;
      }
    }

    match /chats/{chatId} {
      function isChatParticipant() {
        return signedIn() && request.auth.uid in resource.data.participantIds;
      }

      // get must tolerate a missing doc: openChatWith probes for an
      // existing chat before creating it (deterministic uid-pair ids).
      allow get: if signedIn()
        && (resource == null
          || request.auth.uid in resource.data.participantIds);
      allow list: if isChatParticipant();
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2;
      // Participants update message previews and seen markers; the
      // participant list itself is immutable.
      allow update: if isChatParticipant()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage',
          'lastSenderUid',
          'lastMessageAt',
          'seenAt',
          'updatedAt'
        ]);
      allow delete: if false;

      match /messages/{messageId} {
        function parentChat() {
          return get(/databases/$(database)/documents/chats/$(chatId));
        }
        allow read: if signedIn()
          && request.auth.uid in parentChat().data.participantIds;
        allow create: if signedIn()
          && request.auth.uid in parentChat().data.participantIds
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() <= 2000;
        allow update, delete: if false;
      }
    }

    match /teams/{teamId} {
      function isTeamMember() {
        return signedIn() && request.auth.uid in resource.data.memberIds;
      }

      allow read: if isTeamMember();
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.memberIds;
      // Membership management (captain adds, members leave, captain
      // promotion) is enforced in the service layer; rules guarantee only
      // current members can touch the team at all.
      allow update: if isTeamMember();
      allow delete: if isTeamMember();

      match /messages/{messageId} {
        function parentTeam() {
          return get(/databases/$(database)/documents/teams/$(teamId));
        }
        allow read: if signedIn()
          && request.auth.uid in parentTeam().data.memberIds;
        allow create: if signedIn()
          && request.auth.uid in parentTeam().data.memberIds
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() <= 2000;
        allow update, delete: if false;
      }
    }

    match /venues/{venueId} {
      // Venues are managed by an admin tool or backend only.
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /payments/{paymentId} {
      // Payment records are written exclusively by Cloud Functions after
      // a verified Stripe charge. No client writes, ever.
      allow create: if false;

      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid
          || resource.data.organiserId == request.auth.uid);

      allow update, delete: if false;
    }
  }
}
